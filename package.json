{
  "name": "pi-basic-tools",
  "version": "0.1.0",
  "description": "Standalone core productivity tools for pi: multi-edit, question, todo, files, fetch, answer, Sourcegraph, and built-in search activation.",
  "repository": {
    "type": "git",
    "url": "https://github.com/lulucatdev/pi-basic-tools.git"
  },
  "license": "MIT",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "editing",
    "search"
  ],
  "pi": {
    "extensions": [
      "./extensions/multi-edit.ts",
      "./extensions/files.ts",
      "./extensions/fetch.ts",
      "./extensions/enable-builtin-search.ts",
      "./extensions/basic-tools.ts",
      "./extensions/answer.ts",
      "./extensions/sourcegraph.ts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  }
}
